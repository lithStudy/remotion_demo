                  "slideLeft",
                  "slideBottom",
                  "zoomIn",
                  "fadeIn"
                ],
                "default": "breathe"
              }
            }
          },
          "anchor": {
            "type": "object",
            "required": [
              "text"
            ],
            "properties": {
              "text": {
