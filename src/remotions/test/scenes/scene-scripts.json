          "template": "CENTER_FOCUS",
          "param": {
            "imageSrc": "images/test/2_6.png",
            "enterEffect": "breathe",
            "content": [
              {
                "text": "所以，当我们遇到不同声音时，",
                "startFrame": 0,
                "durationFrames": 68,
                "anchor": null,
                "anchorColor": null
              },
              {
                "text": "大脑会本能地把它当成一种“生存威胁”。",
                "startFrame": 67,
                "durationFrames": 92,
                "anchor": null,
                "anchorColor": null
              }
            ],
            "totalDurationFrames": 159,
            "anchors": []
          }
