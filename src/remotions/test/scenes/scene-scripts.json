                "anchorColor": null
              },
              {
                "text": "正精准地利用这个Bug",
                "startFrame": 48,
                "durationFrames": 58,
                "anchor": null,
                "anchorColor": null
              },
              {
                "text": "把我们关进信息囚笼。",
                "startFrame": 105,
                "durationFrames": 49,
                "anchor": null,
                "anchorColor": null
              }
            ],
            "totalDurationFrames": 154,
            "anchors": []
          }
        },
        {
          "order": 4,
          "narrativeType": "算法如何作用",
          "reasoning": "解释平台通过推送认同观点来延长用户停留时间。",
          "template": "CENTER_FOCUS",
          "param": {
            "imageSrc": "images/test/2_4.png",
            "enterEffect": "breathe",
            "content": [
              {
                "text": "那些平台为了让你多刷半小时，",
                "startFrame": 0,
                "durationFrames": 68,
                "anchor": null,
                "anchorColor": null
              },
              {
                "text": "会不断推送你认同的观点。",
                "startFrame": 67,
                "durationFrames": 58,
                "anchor": null,
                "anchorColor": null
              }
            ],
            "totalDurationFrames": 125,
            "anchors": []
          }
        },
        {
          "order": 5,
          "narrativeType": "算法作用结果",
          "reasoning": "描述长期被算法喂养的后果：视野狭窄，认知失真。",
          "template": "CENTER_FOCUS",
          "param": {
            "imageSrc": "images/test/2_5.png",
            "enterEffect": "breathe",
            "content": [
              {
                "text": "久而久之，我们就像被喂食的宠物，",
                "startFrame": 0,
                "durationFrames": 77,
                "anchor": null,
                "anchorColor": null
              },
              {
                "text": "眼中只剩下一片虚假的繁荣。",
