            "type": "string"
          },
          "anim": {
            "type": "string",
            "enum": [
              "spring",
              "slideUp",
              "popIn",
              "highlight"
            ]
          },
          "audioEffect": {
            "type": "string",
            "enum": [
              "impact_thud",
              "ping",
              "woosh"
            ]
          }
        }
      }
    }
  },
  "required": [
