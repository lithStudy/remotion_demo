    {
      "sceneId": 3,
      "sceneName": "概念引入：确认偏误",
      "items": [
        {
          "order": 1,
          "narrativeType": "术语引入",
          "reasoning": "引入心理学概念“确认偏误”，为后续分析提供理论基础。",
          "template": "CONCEPT_CARD",
          "param": {
            "imageSrc": "images/test/3_1.png",
            "conceptName": "确认偏误",
            "content": [
              {
                "text": "在心理学上，这种现象有一个著名的核心概念，",
                "startFrame": 0,
                "durationFrames": 102,
                "anchor": null,
                "anchorColor": null
              },
              {
                "text": "叫作**“确认偏误”**",
                "startFrame": 101,
                "durationFrames": 64,
                "anchor": null,
                "anchorColor": null
              },
              {
                "text": "（Confirmation Bias）。",
                "startFrame": 164,
                "durationFrames": 97,
                "anchor": null,
                "anchorColor": null
              }
            ],
            "totalDurationFrames": 262,
            "anchors": []
          }
        },
        {
          "order": 2,
          "narrativeType": "概念解释",
          "reasoning": "用通俗易懂的语言解释确认偏误的含义。",
          "template": "CENTER_FOCUS",
          "param": {
            "imageSrc": "images/test/3_2.png",
            "enterEffect": "breathe",
            "content": [
              {
                "text": "简单通俗地说，",
                "startFrame": 0,
                "durationFrames": 34,
                "anchor": null,
                "anchorColor": null
              },
              {
                "text": "确认偏误就像是我们大脑自带的一副“有色滤镜”。",
                "startFrame": 33,
                "durationFrames": 112,
                "anchor": null,
                "anchorColor": null
              }
            ],
            "totalDurationFrames": 146,
            "anchors": []
          }
        },
        {
          "order": 3,
          "narrativeType": "确认偏误功能1：自动美颜",
          "reasoning": "解释确认偏误的第一个功能：自动美颜，选择性接收信息。",
          "template": "CENTER_FOCUS",
          "param": {
            "imageSrc": "images/test/3_3.png",
            "enterEffect": "breathe",
            "content": [
              {
                "text": "当我们先入为主地相信一个观点时，",
                "startFrame": 0,
                "durationFrames": 78,
                "anchor": null,
                "anchorColor": null
              },
              {
                "text": "我们的脑子会自动开启两个功能：",
                "startFrame": 77,
                "durationFrames": 73,
                "anchor": null,
                "anchorColor": null
              },
              {
                "text": "**第一，是“自动美颜”**，",
                "startFrame": 150,
                "durationFrames": 73,
                "anchor": null,
                "anchorColor": null
              },
              {
                "text": "凡是能证明我正确的信息，",
                "startFrame": 222,
                "durationFrames": 59,
                "anchor": null,
                "anchorColor": null
              },
              {
                "text": "哪怕漏洞百出，我们也觉得是真理；",
                "startFrame": 281,
                "durationFrames": 78,
                "anchor": null,
                "anchorColor": null
              }
            ],
            "totalDurationFrames": 359,
            "anchors": []
          }
        },
        {
          "order": 4,
          "narrativeType": "确认偏误功能2：一键拉黑",
          "reasoning": "解释确认偏误的第二个功能：一键拉黑，屏蔽反对信息。",
          "template": "CENTER_FOCUS",
          "param": {
            "imageSrc": "images/test/3_4.png",
            "enterEffect": "breathe",
            "content": [
              {
                "text": "**第二，是“一键拉黑”**，",
                "startFrame": 0,
                "durationFrames": 73,
                "anchor": null,
                "anchorColor": null
              },
              {
                "text": "凡是反驳我们的证据，",
                "startFrame": 72,
                "durationFrames": 49,
                "anchor": null,
                "anchorColor": null
              },
              {
                "text": "哪怕铁证如山，我们也觉得那是造谣。",
                "startFrame": 121,
                "durationFrames": 83,
                "anchor": null,
                "anchorColor": null
              }
            ],
            "totalDurationFrames": 204,
            "anchors": []
          }
        },
        {
          "order": 5,
          "narrativeType": "举例说明",
          "reasoning": "通过热恋中的姑娘的例子，生动形象地说明确认偏误。",
          "template": "CENTER_FOCUS",
          "param": {
            "imageSrc": "images/test/3_5.png",
            "enterEffect": "breathe",
            "content": [
              {
                "text": "这就像是一个正在热恋中的姑娘，",
                "startFrame": 0,
                "durationFrames": 73,
                "anchor": null,
                "anchorColor": null
              },
              {
                "text": "她觉得男朋友哪儿都好。",
                "startFrame": 72,
                "durationFrames": 54,
                "anchor": null,
                "anchorColor": null
              },
              {
                "text": "男朋友迟到那是“有个性”，",
                "startFrame": 126,
                "durationFrames": 64,
                "anchor": null,
                "anchorColor": null
              },
              {
                "text": "男朋友不洗澡那是“纯爷们”。",
                "startFrame": 189,
                "durationFrames": 68,
                "anchor": null,
                "anchorColor": null
              }
            ],
            "totalDurationFrames": 257,
            "anchors": []
          }
        },
        {
          "order": 6,
          "narrativeType": "举例递进",
          "reasoning": "继续用热恋的例子，强化确认偏误的作用。",
          "template": "CENTER_FOCUS",
          "param": {
            "imageSrc": "images/test/3_6.png",
            "enterEffect": "breathe",
            "content": [
              {
                "text": "哪怕闺蜜拿出一叠男方劈腿的证据，",
                "startFrame": 0,
                "durationFrames": 78,
                "anchor": null,
                "anchorColor": null
              },
              {
                "text": "她也能脑补出那是",
                "startFrame": 77,
                "durationFrames": 44,
                "anchor": null,
                "anchorColor": null
              },
              {
                "text": "“坏女人在勾引我男人”。",
                "startFrame": 121,
                "durationFrames": 59,
                "anchor": null,
                "anchorColor": null
              }
            ],
            "totalDurationFrames": 180,
            "anchors": []
          }
        },
        {
          "order": 7,
          "narrativeType": "总结强调",
          "reasoning": "总结强调事实不重要，大脑只会寻找支持自己观点的证据。",
          "template": "CENTER_FOCUS",
          "param": {
            "imageSrc": "images/test/3_7.png",
            "enterEffect": "breathe",
            "content": [
              {
                "text": "这时候，事实已经不重要了，",
                "startFrame": 0,
                "durationFrames": 64,
                "anchor": null,
                "anchorColor": null
              },
              {
                "text": "大脑只会疯狂寻找能支持",
                "startFrame": 63,
                "durationFrames": 59,
                "anchor": null,
                "anchorColor": null
              },
              {
                "text": "“我没看错人”的证据。",
                "startFrame": 121,
                "durationFrames": 54,
                "anchor": null,
                "anchorColor": null
              }
            ],
            "totalDurationFrames": 175,
            "anchors": []
          }
        },
        {
          "order": 8,
          "narrativeType": "揭示本质",
          "reasoning": "揭示互联网讨论的本质：一场证明自己是对的心理游戏。",
          "template": "CENTER_FOCUS",
          "param": {
            "imageSrc": "images/test/3_8.png",
            "enterEffect": "breathe",
            "content": [
              {
                "text": "在互联网讨论中，",
                "startFrame": 0,
                "durationFrames": 39,
                "anchor": null,
                "anchorColor": null
              },
              {
                "text": "很多人其实并不是在寻找真理，",
                "startFrame": 38,
                "durationFrames": 68,
                "anchor": null,
                "anchorColor": null
              },
              {
                "text": "而是在玩一场名为",
                "startFrame": 106,
                "durationFrames": 44,
                "anchor": null,
                "anchorColor": null
