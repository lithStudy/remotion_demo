      "items": {
        "type": "object",
        "required": [
          "text",
          "showFrom"
        ],
        "properties": {
          "text": {
            "type": "string",
            "description": "要展示的锚点词"
          },
          "showFrom": {
            "type": "integer",
            "format": "content_index",
            "description": "content 数组下标（0-based），非帧数；合法范围 0～(content 条数-1)，超出会被校验丢弃"
          },
          "color": {
            "type": "string"
          },
          "anim": {
            "type": "string",
            "enum": [
              "spring",
              "slideUp",
              "popIn",
              "highlight"
            ]
          },
          "audioEffect": {
            "type": "string",
            "enum": [
              "impact_thud",
              "ping",
              "woosh"
            ]
          }
        }
