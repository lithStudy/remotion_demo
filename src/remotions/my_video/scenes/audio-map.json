{
  "scene1_1_0": {
    "duration": 2.448,
    "file": "/audio/my_video/scene1/01_正文_0.mp3",
    "sceneId": "scene1",
    "order": 1,
    "subOrder": 0,
    "type": "正文",
    "text": "事情要从一百多年前说起"
  },
  "scene1_2_0": {
    "duration": 1.26,
    "file": "/audio/my_video/scene1/02_正文_0.mp3",
    "sceneId": "scene1",
    "order": 2,
    "subOrder": 0,
    "type": "正文",
    "text": "1914年"
  },
  "scene1_2_1": {
    "duration": 5.868,
    "file": "/audio/my_video/scene1/02_正文_1.mp3",
    "sceneId": "scene1",
    "order": 2,
    "subOrder": 1,
    "type": "正文",
    "text": "英国政府购买了一家在伊朗开采石油的企业（英伊石油公司）51%的股份"
  },
  "scene1_2_2": {
    "duration": 2.556,
    "file": "/audio/my_video/scene1/02_正文_2.mp3",
    "sceneId": "scene1",
    "order": 2,
    "subOrder": 2,
    "type": "正文",
    "text": "获得了实际的石油开采控制权"
  },
  "scene1_3_0": {
    "duration": 5.4,
    "file": "/audio/my_video/scene1/03_正文_0.mp3",
    "sceneId": "scene1",
    "order": 3,
    "subOrder": 0,
    "type": "正文",
    "text": "虽然英国在石油开采的过程中投入了大量的人力物力和开采技术"
  },
  "scene1_3_1": {
    "duration": 2.412,
    "file": "/audio/my_video/scene1/03_正文_1.mp3",
    "sceneId": "scene1",
    "order": 3,
    "subOrder": 1,
    "type": "正文",
    "text": "但也赚取了极其惊人的财富"
  },
  "scene1_3_2": {
    "duration": 3.06,
    "file": "/audio/my_video/scene1/03_正文_2.mp3",
    "sceneId": "scene1",
    "order": 3,
    "subOrder": 2,
    "type": "正文",
    "text": "仅在1945年至1950年间"
  },
  "scene1_3_3": {
    "duration": 4.068,
    "file": "/audio/my_video/scene1/03_正文_3.mp3",
    "sceneId": "scene1",
    "order": 3,
    "subOrder": 3,
    "type": "正文",
    "text": "AIOC就从伊朗石油中赚取了2.5亿英镑"
  },
  "scene2_1_0": {
    "duration": 1.764,
    "file": "/audio/my_video/scene2/01_正文_0.mp3",
    "sceneId": "scene2",
    "order": 1,
    "subOrder": 0,
    "type": "正文",
    "text": "后来伊朗看着眼红了"
  },
  "scene2_1_1": {
    "duration": 2.772,
    "file": "/audio/my_video/scene2/01_正文_1.mp3",
    "sceneId": "scene2",
    "order": 1,
    "subOrder": 1,
    "type": "正文",
    "text": "觉得这是一种极度不公平的资源掠夺"
  },
  "scene2_1_2": {
    "duration": 2.412,
    "file": "/audio/my_video/scene2/01_正文_2.mp3",
    "sceneId": "scene2",
    "order": 1,
    "subOrder": 2,
    "type": "正文",
    "text": "这点燃了伊朗的民族主义情绪"
  },
  "scene2_1_3": {
    "duration": 5.364,
    "file": "/audio/my_video/scene2/01_正文_3.mp3",
    "sceneId": "scene2",
    "order": 1,
    "subOrder": 3,
    "type": "正文",
    "text": "促使摩萨台总理在1951年推动并正式通过了《石油国有化法案》"
  },
  "scene2_1_4": {
    "duration": 2.808,
    "file": "/audio/my_video/scene2/01_正文_4.mp3",
    "sceneId": "scene2",
    "order": 1,
    "subOrder": 4,
    "type": "正文",
    "text": "强行将这个英伊石油公司收为国有"
  },
  "scene2_2_0": {
    "duration": 1.656,
    "file": "/audio/my_video/scene2/02_正文_0.mp3",
    "sceneId": "scene2",
    "order": 2,
    "subOrder": 0,
    "type": "正文",
    "text": "英国对此非常愤怒"
  },
  "scene2_2_1": {
    "duration": 5.112,
    "file": "/audio/my_video/scene2/02_正文_1.mp3",
    "sceneId": "scene2",
    "order": 2,
    "subOrder": 1,
    "type": "正文",
    "text": "认为这是单方面撕毁了双方在1933年签署的石油特许权协议"
  },
  "scene2_2_2": {
    "duration": 1.764,
    "file": "/audio/my_video/scene2/02_正文_2.mp3",
    "sceneId": "scene2",
    "order": 2,
    "subOrder": 2,
    "type": "正文",
    "text": "是非法的违约行为"
  },
  "scene2_2_3": {
    "duration": 3.348,
    "file": "/audio/my_video/scene2/02_正文_3.mp3",
    "sceneId": "scene2",
    "order": 2,
    "subOrder": 3,
    "type": "正文",
    "text": "于是对伊朗实施了严厉的经济制裁和石油禁运"
  },
  "scene2_2_4": {
    "duration": 3.816,
    "file": "/audio/my_video/scene2/02_正文_4.mp3",
    "sceneId": "scene2",
    "order": 2,
    "subOrder": 4,
    "type": "正文",
    "text": "军情六处还率先制定了推翻摩萨台的“靴子行动”"
  },
  "scene2_3_0": {
    "duration": 2.016,
    "file": "/audio/my_video/scene2/03_正文_0.mp3",
    "sceneId": "scene2",
    "order": 3,
    "subOrder": 0,
    "type": "正文",
    "text": "但是，由于局势恶化"
  },
  "scene2_3_1": {
    "duration": 3.852,
    "file": "/audio/my_video/scene2/03_正文_1.mp3",
    "sceneId": "scene2",
    "order": 3,
    "subOrder": 1,
    "type": "正文",
    "text": "英国外交官和情报人员随后被驱逐出伊朗"
  },
  "scene2_3_2": {
    "duration": 2.268,
    "file": "/audio/my_video/scene2/03_正文_2.mp3",
    "sceneId": "scene2",
    "order": 3,
    "subOrder": 2,
    "type": "正文",
    "text": "导致英国没有力量实施行动"
  },
  "scene2_4_0": {
    "duration": 3.096,
    "file": "/audio/my_video/scene2/04_正文_0.mp3",
    "sceneId": "scene2",
    "order": 4,
    "subOrder": 0,
    "type": "正文",
    "text": "于是英国想要拉美国下水，帮他们做这个事情"
  },
  "scene2_4_1": {
    "duration": 2.592,
    "file": "/audio/my_video/scene2/04_正文_1.mp3",
    "sceneId": "scene2",
    "order": 4,
    "subOrder": 1,
    "type": "正文",
    "text": "最初美国总统哈里·杜鲁门是拒绝的"
  },
  "scene2_4_2": {
    "duration": 4.248,
    "file": "/audio/my_video/scene2/04_正文_2.mp3",
    "sceneId": "scene2",
    "order": 4,
    "subOrder": 2,
    "type": "正文",
    "text": "但是德怀特·艾森豪威尔于1953年就任美国总统后"
  },
  "scene2_4_3": {
    "duration": 2.124,
    "file": "/audio/my_video/scene2/04_正文_3.mp3",
    "sceneId": "scene2",
    "order": 4,
    "subOrder": 3,
    "type": "正文",
    "text": "当时正值冷战高峰期"
  },
  "scene2_4_4": {
    "duration": 1.908,
    "file": "/audio/my_video/scene2/04_正文_4.mp3",
    "sceneId": "scene2",
    "order": 4,
    "subOrder": 4,
    "type": "正文",
    "text": "艾森豪威尔政府认为"
  },
  "scene2_4_5": {
    "duration": 3.312,
    "file": "/audio/my_video/scene2/04_正文_5.mp3",
    "sceneId": "scene2",
    "order": 4,
    "subOrder": 5,
    "type": "正文",
    "text": "英国的石油禁运导致伊朗经济濒临崩溃"
  },
  "scene2_4_6": {
    "duration": 4.248,
    "file": "/audio/my_video/scene2/04_正文_6.mp3",
    "sceneId": "scene2",
    "order": 4,
    "subOrder": 6,
    "type": "正文",
    "text": "这种混乱局面极有可能导致伊朗国内的共产主义政党夺权"
  },
  "scene2_4_7": {
    "duration": 1.908,
    "file": "/audio/my_video/scene2/04_正文_7.mp3",
    "sceneId": "scene2",
    "order": 4,
    "subOrder": 7,
    "type": "正文",
    "text": "或者迫使伊朗倒向苏联"
  },
  "scene2_5_0": {
    "duration": 1.908,
    "file": "/audio/my_video/scene2/05_正文_0.mp3",
    "sceneId": "scene2",
    "order": 5,
    "subOrder": 0,
    "type": "正文",
    "text": "因此，美国决定介入"
  },
  "scene2_5_1": {
    "duration": 2.196,
    "file": "/audio/my_video/scene2/05_正文_1.mp3",
    "sceneId": "scene2",
    "order": 5,
    "subOrder": 1,
    "type": "正文",
    "text": "此时美国介入的核心动机是"
  },
  "scene2_5_2": {
    "duration": 3.276,
    "file": "/audio/my_video/scene2/05_正文_2.mp3",
    "sceneId": "scene2",
    "order": 5,
    "subOrder": 2,
    "type": "正文",
    "text": "防止这个中东战略重地落入苏联阵营"
  },
  "scene2_5_3": {
    "duration": 2.52,
    "file": "/audio/my_video/scene2/05_正文_3.mp3",
    "sceneId": "scene2",
    "order": 5,
    "subOrder": 3,
    "type": "正文",
    "text": "而不仅仅是为了帮英国抢回石油"
  },
  "scene3_1_0": {
    "duration": 6.912,
    "file": "/audio/my_video/scene3/01_正文_0.mp3",
    "sceneId": "scene3",
    "order": 1,
    "subOrder": 0,
    "type": "正文",
    "text": "于是在1953年美国策划并参与了推翻伊朗民选总理穆罕默德·摩萨台的“阿贾克斯行动”"
  },
  "scene3_1_1": {
    "duration": 3.168,
    "file": "/audio/my_video/scene3/01_正文_1.mp3",
    "sceneId": "scene3",
    "order": 1,
    "subOrder": 1,
    "type": "正文",
    "text": "扶持了亲美但独裁的“巴列维国王”上台"
  },
  "scene3_2_0": {
    "duration": 2.844,
    "file": "/audio/my_video/scene3/02_正文_0.mp3",
    "sceneId": "scene3",
    "order": 2,
    "subOrder": 0,
    "type": "正文",
    "text": "巴列维国王在伊朗搞高压统治"
  },
  "scene3_2_1": {
    "duration": 1.404,
    "file": "/audio/my_video/scene3/02_正文_1.mp3",
    "sceneId": "scene3",
    "order": 2,
    "subOrder": 1,
    "type": "正文",
    "text": "虽然经济搞好了"
  },
  "scene3_2_2": {
    "duration": 1.62,
    "file": "/audio/my_video/scene3/02_正文_2.mp3",
    "sceneId": "scene3",
    "order": 2,
    "subOrder": 2,
    "type": "正文",
    "text": "但是没有政治自由"
  },
  "scene3_2_3": {
    "duration": 2.592,
    "file": "/audio/my_video/scene3/02_正文_3.mp3",
    "sceneId": "scene3",
    "order": 2,
    "subOrder": 3,
    "type": "正文",
    "text": "他亲手教会伊朗人民什么是民主"
  },
  "scene3_2_4": {
    "duration": 3.276,
    "file": "/audio/my_video/scene3/02_正文_4.mp3",
    "sceneId": "scene3",
    "order": 2,
    "subOrder": 4,
    "type": "正文",
    "text": "但是自己却舍不得权利而搞君主专制"
  },
  "scene3_2_5": {
    "duration": 2.772,
    "file": "/audio/my_video/scene3/02_正文_5.mp3",
    "sceneId": "scene3",
    "order": 2,
    "subOrder": 5,
    "type": "正文",
    "text": "这种催发民智但又不放权的操作"
  },
  "scene3_2_6": {
    "duration": 4.356,
    "file": "/audio/my_video/scene3/02_正文_6.mp3",
    "sceneId": "scene3",
    "order": 2,
    "subOrder": 6,
    "type": "正文",
    "text": "导致了伊朗于1979年爆发了“伊斯兰革命”推翻了国王"
  },
  "scene3_2_7": {
    "duration": 3.204,
    "file": "/audio/my_video/scene3/02_正文_7.mp3",
    "sceneId": "scene3",
    "order": 2,
    "subOrder": 7,
    "type": "正文",
    "text": "建立了反美的政教合一的伊斯兰共和国"
  },
  "scene3_3_0": {
    "duration": 3.168,
    "file": "/audio/my_video/scene3/03_正文_0.mp3",
    "sceneId": "scene3",
    "order": 3,
    "subOrder": 0,
    "type": "正文",
    "text": "同年11月美国收留了流亡的国王治病"
  },
  "scene3_3_1": {
    "duration": 2.52,
    "file": "/audio/my_video/scene3/03_正文_1.mp3",
    "sceneId": "scene3",
    "order": 3,
    "subOrder": 1,
    "type": "正文",
    "text": "这彻底激怒了伊朗的激进学生"
  },
  "scene3_3_2": {
    "duration": 2.412,
    "file": "/audio/my_video/scene3/03_正文_2.mp3",
    "sceneId": "scene3",
    "order": 3,
    "subOrder": 2,
    "type": "正文",
    "text": "他们冲进美国驻德黑兰大使馆"
  },
  "scene3_3_3": {
    "duration": 3.312,
    "file": "/audio/my_video/scene3/03_正文_3.mp3",
    "sceneId": "scene3",
    "order": 3,
    "subOrder": 3,
    "type": "正文",
    "text": "把52名美国外交官蒙上眼睛扣作人质"
  },
  "scene3_3_4": {
    "duration": 2.052,
    "file": "/audio/my_video/scene3/03_正文_4.mp3",
    "sceneId": "scene3",
    "order": 3,
    "subOrder": 4,
    "type": "正文",
    "text": "整整关了444天"
  },
  "scene3_3_5": {
    "duration": 2.556,
    "file": "/audio/my_video/scene3/03_正文_5.mp3",
    "sceneId": "scene3",
    "order": 3,
    "subOrder": 5,
    "type": "正文",
    "text": "从这一天起，两国正式断交"
  },
  "scene3_3_6": {
    "duration": 4.104,
    "file": "/audio/my_video/scene3/03_正文_6.mp3",
    "sceneId": "scene3",
    "order": 3,
    "subOrder": 6,
    "type": "正文",
    "text": "美国人眼里也从此把伊朗看作了“狂热的恐怖国家”"
  },
  "scene4_1_0": {
    "duration": 1.476,
    "file": "/audio/my_video/scene4/01_正文_0.mp3",
    "sceneId": "scene4",
    "order": 1,
    "subOrder": 0,
    "type": "正文",
    "text": "两国结仇后"
  },
  "scene4_1_1": {
    "duration": 2.916,
    "file": "/audio/my_video/scene4/01_正文_1.mp3",
    "sceneId": "scene4",
    "order": 1,
    "subOrder": 1,
    "type": "正文",
    "text": "虽然美国没有实际对伊朗发动战争"
  },
  "scene4_1_2": {
    "duration": 2.844,
    "file": "/audio/my_video/scene4/01_正文_2.mp3",
    "sceneId": "scene4",
    "order": 1,
    "subOrder": 2,
    "type": "正文",
    "text": "但在1980年爆发的“两伊战争”中"
  },
  "scene4_1_3": {
    "duration": 4.968,
    "file": "/audio/my_video/scene4/01_正文_3.mp3",
    "sceneId": "scene4",
    "order": 1,
    "subOrder": 3,
    "type": "正文",
    "text": "美国选择暗中支持当时关系还不错的伊拉克的萨达姆去打伊朗"
  },
  "scene4_1_4": {
    "duration": 2.448,
    "file": "/audio/my_video/scene4/01_正文_4.mp3",
    "sceneId": "scene4",
    "order": 1,
    "subOrder": 4,
    "type": "正文",
    "text": "最严重的是1988年7月3日"
  },
  "scene4_1_5": {
    "duration": 2.304,
    "file": "/audio/my_video/scene4/01_正文_5.mp3",
    "sceneId": "scene4",
    "order": 1,
    "subOrder": 5,
    "type": "正文",
    "text": "美国海军“文森斯”号巡洋舰"
  },
  "scene4_1_6": {
    "duration": 3.348,
    "file": "/audio/my_video/scene4/01_正文_6.mp3",
    "sceneId": "scene4",
    "order": 1,
    "subOrder": 6,
    "type": "正文",
    "text": "因为将客机误判为伊朗战斗机将其击落"
  },
  "scene4_1_7": {
    "duration": 2.376,
    "file": "/audio/my_video/scene4/01_正文_7.mp3",
    "sceneId": "scene4",
    "order": 1,
    "subOrder": 7,
    "type": "正文",
    "text": "导致了290名平民遇难"
  },
  "scene4_1_8": {
    "duration": 2.304,
    "file": "/audio/my_video/scene4/01_正文_8.mp3",
    "sceneId": "scene4",
    "order": 1,
    "subOrder": 8,
    "type": "正文",
    "text": "但在伊朗看来，这就是故意的"
  },
  "scene4_1_9": {
    "duration": 1.548,
    "file": "/audio/my_video/scene4/01_正文_9.mp3",
    "sceneId": "scene4",
    "order": 1,
    "subOrder": 9,
    "type": "正文",
    "text": "这是血海深仇"
  },
  "scene4_2_0": {
    "duration": 1.872,
    "file": "/audio/my_video/scene4/02_正文_0.mp3",
    "sceneId": "scene4",
    "order": 2,
    "subOrder": 0,
    "type": "正文",
    "text": "进入1990年代"
  },
  "scene4_2_1": {
    "duration": 3.564,
    "file": "/audio/my_video/scene4/02_正文_1.mp3",
    "sceneId": "scene4",
    "order": 2,
    "subOrder": 1,
    "type": "正文",
    "text": "克林顿政府开始对伊朗实施全面经济制裁"
  },
  "scene4_2_2": {
    "duration": 5.544,
    "file": "/audio/my_video/scene4/02_正文_2.mp3",
    "sceneId": "scene4",
    "order": 2,
    "subOrder": 2,
    "type": "正文",
    "text": "这让本来因为革命卫队垄断财富而民不聊生的伊朗人民更加雪上加霜"
  },
  "scene4_3_0": {
    "duration": 5.004,
    "file": "/audio/my_video/scene4/03_正文_0.mp3",
    "sceneId": "scene4",
    "order": 3,
    "subOrder": 0,
    "type": "正文",
    "text": "2002年，伊朗反对派组织曝光了伊朗正在秘密进行核试验"
  },
  "scene4_3_1": {
    "duration": 1.944,
    "file": "/audio/my_video/scene4/03_正文_1.mp3",
    "sceneId": "scene4",
    "order": 3,
    "subOrder": 1,
    "type": "正文",
    "text": "这让美国感觉到了威胁"
  },
  "scene4_3_2": {
    "duration": 2.448,
    "file": "/audio/my_video/scene4/03_正文_2.mp3",
    "sceneId": "scene4",
    "order": 3,
    "subOrder": 2,
    "type": "正文",
    "text": "彻底断绝了任何和解的可能"
  },
  "scene5_1_0": {
    "duration": 3.168,
    "file": "/audio/my_video/scene5/01_正文_0.mp3",
    "sceneId": "scene5",
    "order": 1,
    "subOrder": 0,
    "type": "正文",
    "text": "尽管在2013年至2018年间"
  },
  "scene5_1_1": {
    "duration": 2.592,
    "file": "/audio/my_video/scene5/01_正文_1.mp3",
    "sceneId": "scene5",
    "order": 1,
    "subOrder": 1,
    "type": "正文",
    "text": "国际社会与伊朗达成了《伊核协议》"
