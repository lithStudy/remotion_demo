            "totalDurationFrames": 193,
            "anchors": []
          }
        },
        {
          "order": 3,
          "narrativeType": "核心原因2：算法利用",
          "reasoning": "指出互联网算法精准地利用了这个Bug。",
          "template": "CENTER_FOCUS",
          "param": {
            "imageSrc": "images/test/2_3.png",
            "enterEffect": "breathe",
            "content": [
              {
                "text": "而现在的互联网算法，",
                "startFrame": 0,
                "durationFrames": 49,
