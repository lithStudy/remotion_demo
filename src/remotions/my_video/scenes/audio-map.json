    "file": "/audio/my_video/scene5/01_正文_5.mp3",
    "sceneId": "scene5",
    "order": 1,
    "subOrder": 5,
    "type": "正文",
    "text": "并实施了旨在扼杀伊朗经济的“极限施压”政策"
