            ],
            "totalDurationFrames": 169,
            "anchors": []
          }
        },
        {
          "order": 8,
          "narrativeType": "受害者",
          "reasoning": "总结，强调在这种机制下，每个人都是被操纵的受害者。",
          "template": "CENTER_FOCUS",
          "param": {
            "imageSrc": "images/test/2_8.png",
            "enterEffect": "breathe",
            "content": [
              {
                "text": "在这种机制面前，",
                "startFrame": 0,
                "durationFrames": 39,
                "anchor": null,
                "anchorColor": null
              },
              {
                "text": "我们每个人都是被操纵的受害者。",
