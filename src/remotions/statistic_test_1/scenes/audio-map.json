{
  "scene1_1_0": {
    "duration": 1.52,
    "file": "/audio/statistic_test_1/scene1/scene1.mp3",
    "sceneId": "scene1",
    "order": 1,
    "subOrder": 0,
    "type": "正文",
    "text": "冰淇淋卖得越火，",
    "startMs": 0.0,
    "endMs": 1520.4,
    "isFirstInItem": true
  },
  "scene1_1_1": {
    "duration": 1.52,
    "file": "/audio/statistic_test_1/scene1/scene1.mp3",
    "sceneId": "scene1",
    "order": 1,
    "subOrder": 1,
    "type": "正文",
    "text": "溺水的人就越多。",
    "startMs": 1520.4,
    "endMs": 3040.7,
    "isFirstInItem": false
  },
  "scene1_2_0": {
    "duration": 2.661,
    "file": "/audio/statistic_test_1/scene1/scene1.mp3",
    "sceneId": "scene1",
    "order": 2,
    "subOrder": 0,
    "type": "正文",
    "text": "难道是吃冰淇淋会导致溺水吗？",
    "startMs": 3040.7,
    "endMs": 5701.4,
    "isFirstInItem": false
  },
  "scene1_3_0": {
    "duration": 0.95,
    "file": "/audio/statistic_test_1/scene1/scene1.mp3",
    "sceneId": "scene1",
    "order": 3,
    "subOrder": 0,
    "type": "正文",
    "text": "当然不是。",
    "startMs": 5701.4,
    "endMs": 6651.6,
    "isFirstInItem": false
  },
  "scene1_3_1": {
    "duration": 2.091,
    "file": "/audio/statistic_test_1/scene1/scene1.mp3",
    "sceneId": "scene1",
    "order": 3,
    "subOrder": 1,
    "type": "正文",
    "text": "真正的原因是天气热了，",
    "startMs": 6651.6,
    "endMs": 8742.1,
    "isFirstInItem": false
  },
  "scene1_3_2": {
    "duration": 3.041,
    "file": "/audio/statistic_test_1/scene1/scene1.mp3",
    "sceneId": "scene1",
    "order": 3,
    "subOrder": 2,
    "type": "正文",
    "text": "吃冰淇淋和下水游泳的人都变多了。",
    "startMs": 8742.1,
    "endMs": 11782.9,
    "isFirstInItem": false
  },
  "scene1_4_0": {
    "duration": 2.471,
    "file": "/audio/statistic_test_1/scene1/scene1.mp3",
    "sceneId": "scene1",
    "order": 4,
    "subOrder": 0,
    "type": "正文",
    "text": "但就是这种看似离谱的逻辑，",
    "startMs": 11782.9,
    "endMs": 14253.5,
    "isFirstInItem": false
  },
  "scene1_4_1": {
    "duration": 2.091,
    "file": "/audio/statistic_test_1/scene1/scene1.mp3",
    "sceneId": "scene1",
    "order": 4,
    "subOrder": 1,
    "type": "正文",
    "text": "正在悄悄掏空你的钱包，",
    "startMs": 14253.5,
    "endMs": 16344.0,
    "isFirstInItem": false
  },
  "scene1_4_2": {
    "duration": 1.71,
    "file": "/audio/statistic_test_1/scene1/scene1.mp3",
    "sceneId": "scene1",
    "order": 4,
    "subOrder": 2,
    "type": "正文",
    "text": "甚至毁掉你的认知。",
    "startMs": 16344.0,
    "endMs": 18054.4,
    "isFirstInItem": false
  },
  "scene1_5_0": {
    "duration": 3.421,
    "file": "/audio/statistic_test_1/scene1/scene1.mp3",
    "sceneId": "scene1",
    "order": 5,
    "subOrder": 0,
    "type": "正文",
    "text": "这就是一个统计学里最深、最隐蔽的坑：",
    "startMs": 18054.4,
    "endMs": 21475.3,
    "isFirstInItem": false
  },
  "scene1_5_1": {
    "duration": 3.041,
    "file": "/audio/statistic_test_1/scene1/scene1.mp3",
    "sceneId": "scene1",
    "order": 5,
    "subOrder": 1,
    "type": "正文",
    "text": "把“相关性”当成了“因果关系”。",
    "startMs": 21475.3,
    "endMs": 24516.0,
    "isFirstInItem": false
  },
  "scene2_1_0": {
    "duration": 3.099,
    "file": "/audio/statistic_test_1/scene2/scene2.mp3",
    "sceneId": "scene2",
    "order": 1,
    "subOrder": 0,
    "type": "正文",
    "text": "这种思维误区，生活中简直随处可见。",
    "startMs": 0.0,
    "endMs": 3099.0,
    "isFirstInItem": true
  },
  "scene2_2_0": {
    "duration": 1.458,
    "file": "/audio/statistic_test_1/scene2/scene2.mp3",
    "sceneId": "scene2",
    "order": 2,
    "subOrder": 0,
    "type": "正文",
    "text": "比如有人告诉你，",
    "startMs": 3099.0,
    "endMs": 4557.3,
    "isFirstInItem": false
  },
  "scene2_2_1": {
    "duration": 2.917,
    "file": "/audio/statistic_test_1/scene2/scene2.mp3",
    "sceneId": "scene2",
    "order": 2,
    "subOrder": 1,
    "type": "正文",
    "text": "成功的CEO每天都凌晨四点起床。",
    "startMs": 4557.3,
    "endMs": 7474.0,
    "isFirstInItem": false
  },
  "scene2_3_0": {
    "duration": 2.005,
    "file": "/audio/statistic_test_1/scene2/scene2.mp3",
    "sceneId": "scene2",
    "order": 3,
    "subOrder": 0,
    "type": "正文",
    "text": "于是你赶紧定五个闹钟，",
    "startMs": 7474.0,
    "endMs": 9479.2,
    "isFirstInItem": false
  },
  "scene2_3_1": {
    "duration": 2.188,
    "file": "/audio/statistic_test_1/scene2/scene2.mp3",
    "sceneId": "scene2",
    "order": 3,
    "subOrder": 1,
    "type": "正文",
    "text": "强迫自己半夜爬起来死磕。",
    "startMs": 9479.2,
    "endMs": 11666.8,
    "isFirstInItem": false
  },
  "scene2_4_0": {
    "duration": 0.729,
    "file": "/audio/statistic_test_1/scene2/scene2.mp3",
    "sceneId": "scene2",
    "order": 4,
    "subOrder": 0,
    "type": "正文",
    "text": "结果呢？",
    "startMs": 11666.8,
    "endMs": 12395.9,
    "isFirstInItem": false
  },
  "scene2_4_1": {
    "duration": 2.552,
    "file": "/audio/statistic_test_1/scene2/scene2.mp3",
    "sceneId": "scene2",
    "order": 4,
    "subOrder": 1,
    "type": "正文",
    "text": "除了白天哈欠连天、心脏早搏，",
    "startMs": 12395.9,
    "endMs": 14948.0,
    "isFirstInItem": false
  },
  "scene2_4_2": {
    "duration": 2.37,
    "file": "/audio/statistic_test_1/scene2/scene2.mp3",
    "sceneId": "scene2",
    "order": 4,
    "subOrder": 2,
    "type": "正文",
    "text": "你离升职加薪依然遥遥无期。",
    "startMs": 14948.0,
    "endMs": 17317.8,
    "isFirstInItem": false
  },
  "scene2_5_0": {
    "duration": 2.734,
    "file": "/audio/statistic_test_1/scene2/scene2.mp3",
    "sceneId": "scene2",
    "order": 5,
    "subOrder": 0,
    "type": "正文",
    "text": "你以为“早起”是成功的“因”，",
    "startMs": 17317.8,
    "endMs": 20052.2,
    "isFirstInItem": false
  },
  "scene2_5_1": {
    "duration": 5.469,
    "file": "/audio/statistic_test_1/scene2/scene2.mp3",
    "sceneId": "scene2",
    "order": 5,
    "subOrder": 1,
    "type": "正文",
    "text": "但其实，人家可能只是因为工作多到做不完，才被迫早起的“果”。",
    "startMs": 20052.2,
    "endMs": 25521.0,
    "isFirstInItem": false
  },
  "scene2_6_0": {
    "duration": 1.823,
    "file": "/audio/statistic_test_1/scene2/scene2.mp3",
    "sceneId": "scene2",
    "order": 6,
    "subOrder": 0,
    "type": "正文",
    "text": "你把结果当成了原因，",
    "startMs": 25521.0,
    "endMs": 27343.9,
    "isFirstInItem": false
  },
  "scene2_6_1": {
    "duration": 1.276,
    "file": "/audio/statistic_test_1/scene2/scene2.mp3",
    "sceneId": "scene2",
    "order": 6,
    "subOrder": 1,
    "type": "正文",
    "text": "怎么可能成功？",
    "startMs": 27343.9,
    "endMs": 28620.0,
    "isFirstInItem": false
  },
  "scene3_1_0": {
    "duration": 1.911,
    "file": "/audio/statistic_test_1/scene3/scene3.mp3",
    "sceneId": "scene3",
    "order": 1,
    "subOrder": 0,
    "type": "正文",
    "text": "再举个更扎心的例子。",
    "startMs": 0.0,
    "endMs": 1911.4,
    "isFirstInItem": true
  },
  "scene3_2_0": {
    "duration": 4.205,
    "file": "/audio/statistic_test_1/scene3/scene3.mp3",
    "sceneId": "scene3",
    "order": 2,
    "subOrder": 0,
    "type": "正文",
    "text": "很多人看到村里的长寿老人天天抽旱烟、喝白酒，",
    "startMs": 1911.4,
    "endMs": 6116.6,
    "isFirstInItem": false
  },
  "scene3_2_1": {
    "duration": 2.103,
    "file": "/audio/statistic_test_1/scene3/scene3.mp3",
    "sceneId": "scene3",
    "order": 2,
    "subOrder": 1,
    "type": "正文",
    "text": "就觉得烟酒是长寿秘诀。",
    "startMs": 6116.6,
    "endMs": 8219.1,
    "isFirstInItem": false
  },
  "scene3_3_0": {
    "duration": 2.867,
    "file": "/audio/statistic_test_1/scene3/scene3.mp3",
    "sceneId": "scene3",
    "order": 3,
    "subOrder": 0,
    "type": "正文",
    "text": "这在统计学上叫“幸存者偏差”。",
    "startMs": 8219.1,
    "endMs": 11086.3,
    "isFirstInItem": false
  },
  "scene3_4_0": {
    "duration": 0.765,
    "file": "/audio/statistic_test_1/scene3/scene3.mp3",
    "sceneId": "scene3",
    "order": 4,
    "subOrder": 0,
    "type": "正文",
    "text": "真相是，",
    "startMs": 11086.3,
    "endMs": 11850.9,
    "isFirstInItem": false
  },
  "scene3_4_1": {
    "duration": 3.441,
    "file": "/audio/statistic_test_1/scene3/scene3.mp3",
    "sceneId": "scene3",
    "order": 4,
    "subOrder": 1,
    "type": "正文",
    "text": "那些因为抽烟喝酒早早把身体搞垮的人，",
    "startMs": 11850.9,
    "endMs": 15291.4,
    "isFirstInItem": false
  },
  "scene3_4_2": {
    "duration": 3.823,
    "file": "/audio/statistic_test_1/scene3/scene3.mp3",
    "sceneId": "scene3",
    "order": 4,
    "subOrder": 2,
    "type": "正文",
    "text": "根本没机会活到八九十岁，站到你面前说话。",
    "startMs": 15291.4,
    "endMs": 19114.3,
    "isFirstInItem": false
  },
  "scene3_5_0": {
    "duration": 2.676,
    "file": "/audio/statistic_test_1/scene3/scene3.mp3",
    "sceneId": "scene3",
    "order": 5,
    "subOrder": 0,
    "type": "正文",
    "text": "你看到的只是偶然的“相关”，",
    "startMs": 19114.3,
    "endMs": 21790.3,
    "isFirstInItem": false
  },
  "scene3_5_1": {
    "duration": 2.294,
    "file": "/audio/statistic_test_1/scene3/scene3.mp3",
    "sceneId": "scene3",
    "order": 5,
    "subOrder": 1,
    "type": "正文",
    "text": "根本不是必然的“因果”。",
    "startMs": 21790.3,
    "endMs": 24084.0,
    "isFirstInItem": false
  },
  "scene4_1_0": {
    "duration": 4.033,
    "file": "/audio/statistic_test_1/scene4/scene4.mp3",
    "sceneId": "scene4",
    "order": 1,
    "subOrder": 0,
    "type": "正文",
    "text": "要是分不清这两者的区别，现实中可是要吃大亏的。",
    "startMs": 0.0,
    "endMs": 4032.7,
    "isFirstInItem": true
  },
  "scene4_2_0": {
    "duration": 1.052,
    "file": "/audio/statistic_test_1/scene4/scene4.mp3",
    "sceneId": "scene4",
    "order": 2,
    "subOrder": 0,
    "type": "正文",
    "text": "比如相亲时，",
    "startMs": 4032.7,
    "endMs": 5084.8,
    "isFirstInItem": false
  },
  "scene4_2_1": {
    "duration": 3.331,
    "file": "/audio/statistic_test_1/scene4/scene4.mp3",
    "sceneId": "scene4",
    "order": 2,
    "subOrder": 1,
    "type": "正文",
    "text": "看到对方穿一身名牌，就觉得他事业有成。",
    "startMs": 5084.8,
    "endMs": 8416.2,
    "isFirstInItem": false
  },
  "scene4_3_0": {
    "duration": 0.526,
    "file": "/audio/statistic_test_1/scene4/scene4.mp3",
    "sceneId": "scene4",
    "order": 3,
    "subOrder": 0,
    "type": "正文",
    "text": "其实，",
    "startMs": 8416.2,
    "endMs": 8942.2,
    "isFirstInItem": false
  },
  "scene4_3_1": {
    "duration": 2.805,
    "file": "/audio/statistic_test_1/scene4/scene4.mp3",
    "sceneId": "scene4",
    "order": 3,
    "subOrder": 1,
    "type": "正文",
    "text": "那身西装可能只是他为了掩盖负债，",
    "startMs": 8942.2,
    "endMs": 11747.6,
    "isFirstInItem": false
  },
  "scene4_3_2": {
    "duration": 1.753,
    "file": "/audio/statistic_test_1/scene4/scene4.mp3",
    "sceneId": "scene4",
    "order": 3,
    "subOrder": 2,
    "type": "正文",
    "text": "花两百块租来的道具。",
    "startMs": 11747.6,
    "endMs": 13500.9,
    "isFirstInItem": false
  },
  "scene4_4_0": {
    "duration": 1.227,
    "file": "/audio/statistic_test_1/scene4/scene4.mp3",
    "sceneId": "scene4",
    "order": 4,
    "subOrder": 0,
    "type": "正文",
    "text": "这种逻辑错位，",
    "startMs": 13500.9,
    "endMs": 14728.3,
    "isFirstInItem": false
  },
  "scene4_4_1": {
    "duration": 3.507,
    "file": "/audio/statistic_test_1/scene4/scene4.mp3",
    "sceneId": "scene4",
    "order": 4,
    "subOrder": 1,
    "type": "正文",
    "text": "正是那些“割韭菜大师”最核心的财富密码。",
    "startMs": 14728.3,
    "endMs": 18235.0,
    "isFirstInItem": false
  },
  "scene4_5_0": {
    "duration": 2.63,
    "file": "/audio/statistic_test_1/scene4/scene4.mp3",
    "sceneId": "scene4",
    "order": 5,
    "subOrder": 0,
    "type": "正文",
    "text": "他们天天在朋友圈晒豪车、名表，",
    "startMs": 18235.0,
    "endMs": 20865.1,
    "isFirstInItem": false
  },
  "scene4_5_1": {
    "duration": 3.331,
    "file": "/audio/statistic_test_1/scene4/scene4.mp3",
    "sceneId": "scene4",
    "order": 5,
    "subOrder": 1,
    "type": "正文",
    "text": "暗示你只要买他的课，也能过上这种生活。",
    "startMs": 20865.1,
    "endMs": 24196.5,
    "isFirstInItem": false
  },
  "scene4_6_0": {
    "duration": 1.227,
    "file": "/audio/statistic_test_1/scene4/scene4.mp3",
    "sceneId": "scene4",
    "order": 6,
    "subOrder": 0,
    "type": "正文",
    "text": "但真相往往是：",
    "startMs": 24196.5,
    "endMs": 25423.8,
    "isFirstInItem": false
  },
  "scene4_6_1": {
    "duration": 3.857,
    "file": "/audio/statistic_test_1/scene4/scene4.mp3",
    "sceneId": "scene4",
    "order": 6,
    "subOrder": 1,
    "type": "正文",
    "text": "正因为你交了高昂的学费，他才买得起那辆豪车。",
    "startMs": 25423.8,
    "endMs": 29281.2,
    "isFirstInItem": false
  },
  "scene4_7_0": {
    "duration": 2.279,
    "file": "/audio/statistic_test_1/scene4/scene4.mp3",
    "sceneId": "scene4",
    "order": 7,
    "subOrder": 0,
    "type": "正文",
    "text": "他把你被掏空钱包的“果”，",
    "startMs": 29281.2,
    "endMs": 31560.6,
    "isFirstInItem": false
  },
  "scene4_7_1": {
    "duration": 2.279,
    "file": "/audio/statistic_test_1/scene4/scene4.mp3",
    "sceneId": "scene4",
    "order": 7,
    "subOrder": 1,
    "type": "正文",
    "text": "伪装成了带你赚钱的“因”。",
    "startMs": 31560.6,
    "endMs": 33840.0,
    "isFirstInItem": false
  },
  "scene5_1_0": {
    "duration": 2.148,
    "file": "/audio/statistic_test_1/scene5/scene5.mp3",
    "sceneId": "scene5",
    "order": 1,
    "subOrder": 0,
    "type": "正文",
    "text": "为什么这种骗局屡试不爽？",
    "startMs": 0.0,
    "endMs": 2147.6,
    "isFirstInItem": true
  },
  "scene5_2_0": {
    "duration": 1.969,
    "file": "/audio/statistic_test_1/scene5/scene5.mp3",
    "sceneId": "scene5",
    "order": 2,
    "subOrder": 0,
    "type": "正文",
    "text": "因为我们的大脑太懒了。",
    "startMs": 2147.6,
    "endMs": 4116.2,
    "isFirstInItem": false
  },
  "scene5_3_0": {
    "duration": 3.937,
    "file": "/audio/statistic_test_1/scene5/scene5.mp3",
    "sceneId": "scene5",
    "order": 3,
    "subOrder": 0,
    "type": "正文",
    "text": "人类天生就喜欢给复杂的事物找一个简单的理由，",
    "startMs": 4116.2,
    "endMs": 8053.4,
    "isFirstInItem": false
  },
  "scene5_3_1": {
    "duration": 2.326,
    "file": "/audio/statistic_test_1/scene5/scene5.mp3",
    "sceneId": "scene5",
    "order": 3,
    "subOrder": 1,
    "type": "正文",
    "text": "哪怕这个理由根本站不住脚。",
    "startMs": 8053.4,
    "endMs": 10379.9,
    "isFirstInItem": false
  },
  "scene5_4_0": {
    "duration": 3.758,
    "file": "/audio/statistic_test_1/scene5/scene5.mp3",
    "sceneId": "scene5",
    "order": 4,
    "subOrder": 0,
    "type": "正文",
    "text": "记住，两件事同时发生，不代表它们互相决定。",
    "startMs": 10379.9,
    "endMs": 14138.2,
    "isFirstInItem": false
  },
  "scene5_5_0": {
    "duration": 2.863,
    "file": "/audio/statistic_test_1/scene5/scene5.mp3",
    "sceneId": "scene5",
    "order": 5,
    "subOrder": 0,
    "type": "正文",
    "text": "中间可能隔着一个你看不见的变量，",
    "startMs": 14138.2,
    "endMs": 17001.6,
    "isFirstInItem": false
  },
  "scene5_5_1": {
    "duration": 1.969,
    "file": "/audio/statistic_test_1/scene5/scene5.mp3",
    "sceneId": "scene5",
    "order": 5,
    "subOrder": 1,
    "type": "正文",
    "text": "或者干脆就是纯属巧合。",
    "startMs": 17001.6,
    "endMs": 18970.2,
    "isFirstInItem": false
  },
  "scene5_6_0": {
    "duration": 3.042,
    "file": "/audio/statistic_test_1/scene5/scene5.mp3",
    "sceneId": "scene5",
    "order": 6,
    "subOrder": 0,
    "type": "正文",
    "text": "在这个信息爆炸的时代，分不清因果，",
    "startMs": 18970.2,
    "endMs": 22012.6,
    "isFirstInItem": false
  },
  "scene5_6_1": {
    "duration": 2.863,
    "file": "/audio/statistic_test_1/scene5/scene5.mp3",
    "sceneId": "scene5",
    "order": 6,
    "subOrder": 1,
    "type": "正文",
    "text": "你不仅会变穷，还会被骗得团团转。",
    "startMs": 22012.6,
