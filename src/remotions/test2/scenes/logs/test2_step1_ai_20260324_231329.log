    // (如果模板要求图片等其他字段，在此生成，但需符合 Schema 返回纯内容)
    "content": [
      {
        "text": "完整原文片段（顺次无缝拼接，不能漏字）",
        "audioEffect": "音效"
      }
    ],
    "anchors": [
      {
        "text": "被高亮的关键词",
        "showFrom": 0,
        "color": "#颜色",
        "anim": "动画样式"
      }
    ]
  }
}
