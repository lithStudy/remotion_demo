{
  "scene1_1_0": {
    "duration": 2.014,
    "file": "/audio/statistic_test_3/scene1/scene1.mp3",
    "sceneId": "scene1",
    "order": 1,
    "subOrder": 0,
    "type": "正文",
    "text": "别再相信有图有真相了。",
    "startMs": 0.0,
    "endMs": 2013.7,
    "isFirstInItem": true
  },
  "scene1_2_0": {
    "duration": 3.478,
    "file": "/audio/statistic_test_3/scene1/scene1.mp3",
    "sceneId": "scene1",
    "order": 2,
    "subOrder": 0,
    "type": "正文",
    "text": "越是花里胡哨、看着极其专业的数据图表，",
    "startMs": 2013.7,
    "endMs": 5491.9,
    "isFirstInItem": false
  },
  "scene1_2_1": {
    "duration": 3.112,
    "file": "/audio/statistic_test_3/scene1/scene1.mp3",
    "sceneId": "scene1",
    "order": 2,
    "subOrder": 1,
    "type": "正文",
    "text": "越可能是在明目张胆地把你当傻瓜骗。",
    "startMs": 5491.9,
    "endMs": 8604.0,
    "isFirstInItem": false
  },
  "scene2_1_0": {
    "duration": 1.366,
    "file": "/audio/statistic_test_3/scene2/scene2.mp3",
    "sceneId": "scene2",
    "order": 1,
    "subOrder": 0,
    "type": "正文",
    "text": "为什么这么说？",
    "startMs": 0.0,
    "endMs": 1366.2,
    "isFirstInItem": true
  },
  "scene2_1_1": {
    "duration": 2.147,
    "file": "/audio/statistic_test_3/scene2/scene2.mp3",
    "sceneId": "scene2",
    "order": 1,
    "subOrder": 1,
    "type": "正文",
    "text": "因为数字本身不会撒谎，",
    "startMs": 1366.2,
    "endMs": 3513.0,
    "isFirstInItem": false
  },
  "scene2_1_2": {
    "duration": 2.928,
    "file": "/audio/statistic_test_3/scene2/scene2.mp3",
    "sceneId": "scene2",
    "order": 1,
    "subOrder": 2,
    "type": "正文",
    "text": "但是画图的人却可以随便动手脚。",
    "startMs": 3513.0,
    "endMs": 6440.6,
    "isFirstInItem": false
  },
  "scene2_2_0": {
    "duration": 2.928,
    "file": "/audio/statistic_test_3/scene2/scene2.mp3",
    "sceneId": "scene2",
    "order": 2,
    "subOrder": 0,
    "type": "正文",
    "text": "你看那些教你理财的割韭菜大师，",
    "startMs": 6440.6,
    "endMs": 9368.1,
    "isFirstInItem": false
  },
  "scene2_2_1": {
    "duration": 4.098,
    "file": "/audio/statistic_test_3/scene2/scene2.mp3",
    "sceneId": "scene2",
    "order": 2,
    "subOrder": 1,
    "type": "正文",
    "text": "他们最喜欢展示一张收益率一路狂飙的折线图。",
    "startMs": 9368.1,
    "endMs": 13466.6,
    "isFirstInItem": false
  },
  "scene2_3_0": {
    "duration": 2.147,
    "file": "/audio/statistic_test_3/scene2/scene2.mp3",
    "sceneId": "scene2",
    "order": 3,
    "subOrder": 0,
    "type": "正文",
    "text": "看着那条红线直冲云霄，",
    "startMs": 13466.6,
    "endMs": 15613.5,
    "isFirstInItem": false
  },
  "scene2_3_1": {
    "duration": 1.171,
    "file": "/audio/statistic_test_3/scene2/scene2.mp3",
    "sceneId": "scene2",
    "order": 3,
    "subOrder": 1,
    "type": "正文",
    "text": "你热血沸腾，",
    "startMs": 15613.5,
    "endMs": 16784.5,
    "isFirstInItem": false
  },
  "scene2_3_2": {
    "duration": 2.928,
    "file": "/audio/statistic_test_3/scene2/scene2.mp3",
    "sceneId": "scene2",
    "order": 3,
    "subOrder": 2,
    "type": "正文",
    "text": "脑子一热就交了成千上万的学费。",
    "startMs": 16784.5,
    "endMs": 19712.0,
    "isFirstInItem": false
  },
  "scene2_4_0": {
    "duration": 0.781,
    "file": "/audio/statistic_test_3/scene2/scene2.mp3",
    "sceneId": "scene2",
    "order": 4,
    "subOrder": 0,
    "type": "正文",
    "text": "结果呢？",
    "startMs": 19712.0,
    "endMs": 20492.7,
    "isFirstInItem": false
  },
  "scene2_4_1": {
    "duration": 1.952,
    "file": "/audio/statistic_test_3/scene2/scene2.mp3",
    "sceneId": "scene2",
    "order": 4,
    "subOrder": 1,
    "type": "正文",
    "text": "你买进去就天天亏钱。",
    "startMs": 20492.7,
    "endMs": 22444.4,
    "isFirstInItem": false
  },
  "scene2_5_0": {
    "duration": 1.756,
    "file": "/audio/statistic_test_3/scene2/scene2.mp3",
    "sceneId": "scene2",
    "order": 5,
    "subOrder": 0,
    "type": "正文",
    "text": "其实根本没有奇迹，",
    "startMs": 22444.4,
    "endMs": 24200.9,
    "isFirstInItem": false
  },
  "scene2_5_1": {
    "duration": 3.903,
    "file": "/audio/statistic_test_3/scene2/scene2.mp3",
    "sceneId": "scene2",
    "order": 5,
    "subOrder": 1,
    "type": "正文",
    "text": "人家只是鸡贼地截取了行情最好的那三个月，",
    "startMs": 24200.9,
    "endMs": 28104.3,
    "isFirstInItem": false
  },
  "scene2_5_2": {
    "duration": 2.732,
    "file": "/audio/statistic_test_3/scene2/scene2.mp3",
    "sceneId": "scene2",
    "order": 5,
    "subOrder": 2,
    "type": "正文",
    "text": "把跌成狗的前三年全给隐瞒了。",
    "startMs": 28104.3,
    "endMs": 30836.6,
    "isFirstInItem": false
  },
  "scene2_5_3": {
    "duration": 3.903,
    "file": "/audio/statistic_test_3/scene2/scene2.mp3",
    "sceneId": "scene2",
    "order": 5,
    "subOrder": 3,
    "type": "正文",
    "text": "这就是最典型的信息剪裁，专骗你的血汗钱。",
    "startMs": 30836.6,
    "endMs": 34740.0,
    "isFirstInItem": false
  },
  "scene3_1_0": {
    "duration": 2.853,
    "file": "/audio/statistic_test_3/scene3/scene3.mp3",
    "sceneId": "scene3",
    "order": 1,
    "subOrder": 0,
    "type": "正文",
    "text": "说白了，这就叫数据可视化陷阱。",
    "startMs": 0.0,
    "endMs": 2853.4,
    "isFirstInItem": true
  },
  "scene3_1_1": {
    "duration": 1.332,
    "file": "/audio/statistic_test_3/scene3/scene3.mp3",
    "sceneId": "scene3",
    "order": 1,
    "subOrder": 1,
    "type": "正文",
    "text": "这是什么意思？",
    "startMs": 2853.4,
    "endMs": 4185.0,
    "isFirstInItem": false
  },
  "scene3_2_0": {
    "duration": 1.712,
    "file": "/audio/statistic_test_3/scene3/scene3.mp3",
    "sceneId": "scene3",
    "order": 2,
    "subOrder": 0,
    "type": "正文",
    "text": "想象一下你去相亲。",
    "startMs": 4185.0,
    "endMs": 5897.0,
    "isFirstInItem": false
  },
  "scene3_2_1": {
    "duration": 2.853,
    "file": "/audio/statistic_test_3/scene3/scene3.mp3",
    "sceneId": "scene3",
    "order": 2,
    "subOrder": 1,
    "type": "正文",
    "text": "对方给你发了一张大长腿全身照，",
    "startMs": 5897.0,
    "endMs": 8750.4,
    "isFirstInItem": false
  },
  "scene3_2_2": {
    "duration": 2.853,
    "file": "/audio/statistic_test_3/scene3/scene3.mp3",
    "sceneId": "scene3",
    "order": 2,
    "subOrder": 2,
    "type": "正文",
    "text": "看着身材比例完美，气场一米八。",
    "startMs": 8750.4,
    "endMs": 11603.8,
    "isFirstInItem": false
  },
  "scene3_3_0": {
    "duration": 3.424,
    "file": "/audio/statistic_test_3/scene3/scene3.mp3",
    "sceneId": "scene3",
    "order": 3,
    "subOrder": 0,
    "type": "正文",
    "text": "结果你见了真人一看，连一米六都不到。",
    "startMs": 11603.8,
    "endMs": 15027.8,
    "isFirstInItem": false
  },
  "scene3_3_1": {
    "duration": 1.712,
    "file": "/audio/statistic_test_3/scene3/scene3.mp3",
    "sceneId": "scene3",
    "order": 3,
    "subOrder": 1,
    "type": "正文",
    "text": "难道照片是假的吗？",
    "startMs": 15027.8,
    "endMs": 16739.9,
    "isFirstInItem": false
  },
  "scene3_3_2": {
    "duration": 5.516,
    "file": "/audio/statistic_test_3/scene3/scene3.mp3",
    "sceneId": "scene3",
    "order": 3,
    "subOrder": 2,
    "type": "正文",
    "text": "没造假，只是人家拍照的时候用了广角仰拍，还偷偷垫了块砖头。",
    "startMs": 16739.9,
    "endMs": 22256.4,
    "isFirstInItem": false
  },
  "scene3_4_0": {
    "duration": 2.473,
    "file": "/audio/statistic_test_3/scene3/scene3.mp3",
    "sceneId": "scene3",
    "order": 4,
    "subOrder": 0,
    "type": "正文",
    "text": "做图表也是一模一样的套路。",
    "startMs": 22256.4,
    "endMs": 24729.3,
    "isFirstInItem": false
  },
  "scene3_4_1": {
    "duration": 3.234,
    "file": "/audio/statistic_test_3/scene3/scene3.mp3",
    "sceneId": "scene3",
    "order": 4,
    "subOrder": 1,
    "type": "正文",
    "text": "很多图表最爱在坐标轴上搞偷梁换柱。",
    "startMs": 24729.3,
    "endMs": 27963.2,
    "isFirstInItem": false
  },
  "scene3_4_2": {
    "duration": 4.375,
    "file": "/audio/statistic_test_3/scene3/scene3.mp3",
    "sceneId": "scene3",
    "order": 4,
    "subOrder": 2,
    "type": "正文",
    "text": "只要把图表左边纵坐标的起点，从零偷偷改成八十，",
    "startMs": 27963.2,
    "endMs": 32338.4,
    "isFirstInItem": false
  },
  "scene3_4_3": {
    "duration": 2.853,
    "file": "/audio/statistic_test_3/scene3/scene3.mp3",
    "sceneId": "scene3",
    "order": 4,
    "subOrder": 3,
    "type": "正文",
    "text": "原本只涨了百分之二的微弱变化，",
    "startMs": 32338.4,
    "endMs": 35191.8,
    "isFirstInItem": false
  },
  "scene3_4_4": {
    "duration": 3.614,
    "file": "/audio/statistic_test_3/scene3/scene3.mp3",
    "sceneId": "scene3",
    "order": 4,
    "subOrder": 4,
    "type": "正文",
    "text": "在视觉上看着就像是一飞冲天的暴富神话。",
    "startMs": 35191.8,
    "endMs": 38806.0,
    "isFirstInItem": false
  },
  "scene3_4_5": {
    "duration": 2.092,
    "file": "/audio/statistic_test_3/scene3/scene3.mp3",
    "sceneId": "scene3",
    "order": 4,
    "subOrder": 5,
    "type": "正文",
    "text": "刻度稍微拉伸那么一下，",
    "startMs": 38806.0,
    "endMs": 40898.5,
    "isFirstInItem": false
  },
  "scene3_4_6": {
    "duration": 2.473,
    "file": "/audio/statistic_test_3/scene3/scene3.mp3",
    "sceneId": "scene3",
    "order": 4,
    "subOrder": 6,
    "type": "正文",
    "text": "微小的差异就能被放大十倍。",
    "startMs": 40898.5,
    "endMs": 43371.5,
    "isFirstInItem": false
  },
  "scene3_4_7": {
    "duration": 2.092,
    "file": "/audio/statistic_test_3/scene3/scene3.mp3",
    "sceneId": "scene3",
    "order": 4,
    "subOrder": 7,
    "type": "正文",
    "text": "你以为你在看客观事实，",
    "startMs": 43371.5,
    "endMs": 45463.9,
    "isFirstInItem": false
  },
  "scene3_4_8": {
    "duration": 3.424,
    "file": "/audio/statistic_test_3/scene3/scene3.mp3",
    "sceneId": "scene3",
    "order": 4,
    "subOrder": 8,
    "type": "正文",
    "text": "其实你是在看别人精心布置的视觉魔术。",
    "startMs": 45463.9,
    "endMs": 48888.0,
    "isFirstInItem": false
  },
  "scene4_1_0": {
    "duration": 3.108,
    "file": "/audio/statistic_test_3/scene4/scene4.mp3",
    "sceneId": "scene4",
    "order": 1,
    "subOrder": 0,
    "type": "正文",
    "text": "其实在这个注意力被疯狂收割的时代，",
    "startMs": 0.0,
    "endMs": 3108.2,
    "isFirstInItem": true
  },
  "scene4_1_1": {
    "duration": 3.108,
    "file": "/audio/statistic_test_3/scene4/scene4.mp3",
    "sceneId": "scene4",
    "order": 1,
    "subOrder": 1,
    "type": "正文",
    "text": "图表早就不是什么单纯的记录工具了。",
    "startMs": 3108.2,
    "endMs": 6216.4,
    "isFirstInItem": false
  },
  "scene4_1_2": {
    "duration": 2.743,
    "file": "/audio/statistic_test_3/scene4/scene4.mp3",
    "sceneId": "scene4",
    "order": 1,
    "subOrder": 2,
    "type": "正文",
    "text": "它变成了操纵你情绪的终极武器。",
    "startMs": 6216.4,
    "endMs": 8959.0,
    "isFirstInItem": false
  },
  "scene4_2_0": {
    "duration": 3.108,
    "file": "/audio/statistic_test_3/scene4/scene4.mp3",
    "sceneId": "scene4",
    "order": 2,
    "subOrder": 0,
    "type": "正文",
    "text": "不管是商家给你看业绩暴涨的柱状图，",
    "startMs": 8959.0,
    "endMs": 12067.2,
    "isFirstInItem": false
  },
  "scene4_2_1": {
    "duration": 3.474,
    "file": "/audio/statistic_test_3/scene4/scene4.mp3",
    "sceneId": "scene4",
    "order": 2,
    "subOrder": 1,
    "type": "正文",
    "text": "还是推销员给你看疯狂下降的患病率曲线。",
    "startMs": 12067.2,
    "endMs": 15541.1,
    "isFirstInItem": false
  },
  "scene4_2_2": {
    "duration": 3.657,
    "file": "/audio/statistic_test_3/scene4/scene4.mp3",
    "sceneId": "scene4",
    "order": 2,
    "subOrder": 2,
    "type": "正文",
    "text": "他们都在利用你大脑对视觉画面的天然盲从，",
    "startMs": 15541.1,
    "endMs": 19197.8,
    "isFirstInItem": false
  },
  "scene4_2_3": {
    "duration": 2.56,
    "file": "/audio/statistic_test_3/scene4/scene4.mp3",
    "sceneId": "scene4",
    "order": 2,
    "subOrder": 3,
    "type": "正文",
    "text": "直接绕过了你的理性防御机制。",
    "startMs": 19197.8,
    "endMs": 21757.5,
    "isFirstInItem": false
  },
  "scene4_3_0": {
    "duration": 1.097,
    "file": "/audio/statistic_test_3/scene4/scene4.mp3",
    "sceneId": "scene4",
    "order": 3,
    "subOrder": 0,
    "type": "正文",
    "text": "记住一句话，",
    "startMs": 21757.5,
    "endMs": 22854.5,
    "isFirstInItem": false
  },
  "scene4_3_1": {
    "duration": 3.291,
    "file": "/audio/statistic_test_3/scene4/scene4.mp3",
    "sceneId": "scene4",
    "order": 3,
    "subOrder": 1,
    "type": "正文",
    "text": "看图如果不看坐标轴，不看数据基准线，",
    "startMs": 22854.5,
    "endMs": 26145.6,
    "isFirstInItem": false
  },
  "scene4_3_2": {
    "duration": 4.022,
    "file": "/audio/statistic_test_3/scene4/scene4.mp3",
    "sceneId": "scene4",
    "order": 3,
    "subOrder": 2,
    "type": "正文",
    "text": "那你早晚要被这个社会当成最肥的韭菜狠狠收割。",
    "startMs": 26145.6,
    "endMs": 30168.0,
    "isFirstInItem": false
  },
  "scene5_1_0": {
    "duration": 1.24,
    "file": "/audio/statistic_test_3/scene5/scene5.mp3",
    "sceneId": "scene5",
    "order": 1,
    "subOrder": 0,
    "type": "正文",
    "text": "仔细回想一下，",
    "startMs": 0.0,
    "endMs": 1240.0,
    "isFirstInItem": true
  },
  "scene5_1_1": {
    "duration": 2.657,
    "file": "/audio/statistic_test_3/scene5/scene5.mp3",
    "sceneId": "scene5",
    "order": 1,
    "subOrder": 1,
    "type": "正文",
    "text": "你最近在朋友圈或者公司开会时，",
    "startMs": 1240.0,
    "endMs": 3897.1,
    "isFirstInItem": false
  },
  "scene5_1_2": {
    "duration": 3.897,
    "file": "/audio/statistic_test_3/scene5/scene5.mp3",
    "sceneId": "scene5",
    "order": 1,
    "subOrder": 2,
    "type": "正文",
    "text": "看到的那些让你极其焦虑或者极其兴奋的数据图。",
    "startMs": 3897.1,
    "endMs": 7794.3,
    "isFirstInItem": false
  },
  "scene5_1_3": {
    "duration": 3.366,
    "file": "/audio/statistic_test_3/scene5/scene5.mp3",
    "sceneId": "scene5",
    "order": 1,
    "subOrder": 3,
    "type": "正文",
    "text": "你是否仔细看过他们坐标轴的数据基准线？",
    "startMs": 7794.3,
    "endMs": 11160.0,
    "isFirstInItem": false
  }
}