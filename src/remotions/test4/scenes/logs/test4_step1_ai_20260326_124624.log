      }
    ],
    "anchors": [
      {
        "text": "被高亮的关键词",
        "showFrom": 0,
        "color": "#颜色",
        "anim": "动画样式",
        "audioEffect": "可选：impact_thud / ping / woosh 或省略"
      }
    ]
  }
}
