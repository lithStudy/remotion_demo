{
  "scene1_1_0": {
    "duration": 3.75,
    "file": "/audio/statistic_1/scene1/scene1.mp3",
    "sceneId": "scene1",
    "order": 1,
    "subOrder": 0,
    "type": "正文",
    "text": "刷小红书，感觉年轻人，人均爱马仕。",
    "startMs": 0.0,
    "endMs": 3750.0,
    "isFirstInItem": true
  },
  "scene1_1_1": {
    "duration": 3.571,
    "file": "/audio/statistic_1/scene1/scene1.mp3",
    "sceneId": "scene1",
    "order": 1,
    "subOrder": 1,
    "type": "正文",
    "text": "逛知乎，感觉应届生起步年薪百万。",
    "startMs": 3750.0,
    "endMs": 7321.4,
    "isFirstInItem": false
  },
  "scene1_2_0": {
    "duration": 2.107,
    "file": "/audio/statistic_1/scene1/scene1.mp3",
    "sceneId": "scene1",
    "order": 2,
    "subOrder": 0,
    "type": "正文",
    "text": "你是不是也产生过这种错觉：",
    "startMs": 7321.4,
    "endMs": 9428.6,
    "isFirstInItem": false
  },
  "scene1_2_1": {
    "duration": 2.893,
    "file": "/audio/statistic_1/scene1/scene1.mp3",
    "sceneId": "scene1",
    "order": 2,
    "subOrder": 1,
    "type": "正文",
    "text": "“原来全世界只有我这么穷？”",
    "startMs": 9428.6,
    "endMs": 12321.4,
    "isFirstInItem": false
  },
  "scene1_3_0": {
    "duration": 0.607,
    "file": "/audio/statistic_1/scene1/scene1.mp3",
    "sceneId": "scene1",
    "order": 3,
    "subOrder": 0,
    "type": "正文",
    "text": "别焦虑，",
    "startMs": 12321.4,
    "endMs": 12928.6,
    "isFirstInItem": false
  },
  "scene1_3_1": {
    "duration": 4.607,
    "file": "/audio/statistic_1/scene1/scene1.mp3",
    "sceneId": "scene1",
    "order": 3,
    "subOrder": 1,
    "type": "正文",
    "text": "这可能不是你的问题，而是-“样本偏差”-在作祟。",
    "startMs": 12928.6,
    "endMs": 17535.7,
    "isFirstInItem": false
  },
  "scene1_4_0": {
    "duration": 2.369,
    "file": "/audio/statistic_1/scene1/scene1.mp3",
    "sceneId": "scene1",
    "order": 4,
    "subOrder": 0,
    "type": "正文",
    "text": "今天我们聊聊统计素养的核心",
    "startMs": 17535.7,
    "endMs": 19904.8,
    "isFirstInItem": false
  },
  "scene1_4_1": {
    "duration": 4.395,
    "file": "/audio/statistic_1/scene1/scene1.mp3",
    "sceneId": "scene1",
    "order": 4,
    "subOrder": 1,
    "type": "正文",
    "text": "即：被调查的那拨人，真的能代表所有人吗？",
    "startMs": 19904.8,
    "endMs": 24300.0,
    "isFirstInItem": false
  },
  "scene2_1_0": {
    "duration": 1.679,
    "file": "/audio/statistic_1/scene2/scene2.mp3",
    "sceneId": "scene2",
    "order": 1,
    "subOrder": 0,
    "type": "正文",
    "text": "想看穿一份调查报告",
    "startMs": 0.0,
    "endMs": 1678.6,
    "isFirstInItem": true
  },
  "scene2_1_1": {
    "duration": 3.44,
    "file": "/audio/statistic_1/scene2/scene2.mp3",
    "sceneId": "scene2",
    "order": 1,
    "subOrder": 1,
    "type": "正文",
    "text": "你只需要像拿着放大镜一样，盯着那个“漏斗”看：",
    "startMs": 1678.6,
    "endMs": 5119.0,
    "isFirstInItem": false
  },
  "scene2_2_0": {
    "duration": 2.083,
    "file": "/audio/statistic_1/scene2/scene2.mp3",
    "sceneId": "scene2",
    "order": 2,
    "subOrder": 0,
    "type": "正文",
    "text": "样本是怎么选的?",
    "startMs": 5119.0,
    "endMs": 7202.4,
    "isFirstInItem": false
  },
  "scene2_2_1": {
    "duration": 1.452,
    "file": "/audio/statistic_1/scene2/scene2.mp3",
    "sceneId": "scene2",
    "order": 2,
    "subOrder": 1,
    "type": "正文",
    "text": "够随机吗?",
    "startMs": 7202.4,
    "endMs": 8654.8,
    "isFirstInItem": false
  },
  "scene2_2_2": {
    "duration": 1.833,
    "file": "/audio/statistic_1/scene2/scene2.mp3",
    "sceneId": "scene2",
    "order": 2,
    "subOrder": 2,
    "type": "正文",
    "text": "样本量够大吗?",
    "startMs": 8654.8,
    "endMs": 10488.1,
    "isFirstInItem": false
  },
  "scene2_3_0": {
    "duration": 1.31,
    "file": "/audio/statistic_1/scene2/scene2.mp3",
    "sceneId": "scene2",
    "order": 3,
    "subOrder": 0,
    "type": "正文",
    "text": "记住这个万能金句：",
    "startMs": 10488.1,
    "endMs": 11797.6,
    "isFirstInItem": false
  },
  "scene2_3_1": {
    "duration": 3.631,
    "file": "/audio/statistic_1/scene2/scene2.mp3",
    "sceneId": "scene2",
    "order": 3,
    "subOrder": 1,
    "type": "正文",
    "text": "“这个调查是在哪里做的，到底问了谁？”",
    "startMs": 11797.6,
    "endMs": 15428.6,
    "isFirstInItem": false
  },
  "scene2_4_0": {
    "duration": 3.795,
    "file": "/audio/statistic_1/scene2/scene2.mp3",
    "sceneId": "scene2",
    "order": 4,
    "subOrder": 0,
    "type": "正文",
    "text": "接下来，带你看穿四个最常见的“统计陷阱”。",
    "startMs": 15428.6,
    "endMs": 19224.0,
    "isFirstInItem": false
  },
  "scene3_1_0": {
    "duration": 0.786,
    "file": "/audio/statistic_1/scene3/scene3.mp3",
    "sceneId": "scene3",
    "order": 1,
    "subOrder": 0,
    "type": "正文",
    "text": "第一个例子：",
    "startMs": 0.0,
    "endMs": 785.8,
    "isFirstInItem": true
  },
  "scene3_1_1": {
    "duration": 4.405,
    "file": "/audio/statistic_1/scene3/scene3.mp3",
    "sceneId": "scene3",
    "order": 1,
    "subOrder": 1,
    "type": "正文",
    "text": "点外卖时，看到一家网红店评分4.9，全是好评，",
    "startMs": 785.8,
    "endMs": 5190.5,
    "isFirstInItem": false
  },
  "scene3_1_2": {
    "duration": 3.024,
    "file": "/audio/statistic_1/scene3/scene3.mp3",
    "sceneId": "scene3",
    "order": 1,
    "subOrder": 2,
    "type": "正文",
    "text": "结果点回来一吃——难吃得想哭。",
    "startMs": 5190.5,
    "endMs": 8214.3,
    "isFirstInItem": false
  },
  "scene3_2_0": {
    "duration": 2.286,
    "file": "/audio/statistic_1/scene3/scene3.mp3",
    "sceneId": "scene3",
    "order": 2,
    "subOrder": 0,
    "type": "正文",
    "text": "这就是“自选择偏差”。",
    "startMs": 8214.3,
    "endMs": 10500.0,
    "isFirstInItem": false
  },
  "scene3_2_1": {
    "duration": 3.857,
    "file": "/audio/statistic_1/scene3/scene3.mp3",
    "sceneId": "scene3",
    "order": 2,
    "subOrder": 1,
    "type": "正文",
    "text": "仔细看，评论区是不是写着“好评返现3元”？",
    "startMs": 10500.0,
    "endMs": 14357.1,
    "isFirstInItem": false
  },
  "scene3_3_0": {
    "duration": 2.881,
    "file": "/audio/statistic_1/scene3/scene3.mp3",
    "sceneId": "scene3",
    "order": 3,
    "subOrder": 0,
    "type": "正文",
    "text": "为了拿红包的人才会积极评价。",
    "startMs": 14357.1,
    "endMs": 17238.1,
    "isFirstInItem": false
  },
  "scene3_3_1": {
    "duration": 4.702,
    "file": "/audio/statistic_1/scene3/scene3.mp3",
    "sceneId": "scene3",
    "order": 3,
    "subOrder": 1,
    "type": "正文",
    "text": "而那些觉得难吃的人，往往直接拉黑，根本懒得发声。 ",
    "startMs": 17238.1,
    "endMs": 21940.5,
    "isFirstInItem": false
  },
  "scene3_4_0": {
    "duration": 4.123,
    "file": "/audio/statistic_1/scene3/scene3.mp3",
    "sceneId": "scene3",
    "order": 4,
    "subOrder": 0,
    "type": "正文",
    "text": "我们需要警惕：那些“沉默的大多数”到底怎么想。",
    "startMs": 21940.5,
    "endMs": 26064.0,
    "isFirstInItem": false
  },
  "scene4_1_0": {
    "duration": 0.786,
    "file": "/audio/statistic_1/scene4/scene4.mp3",
    "sceneId": "scene4",
    "order": 1,
    "subOrder": 0,
    "type": "正文",
    "text": "第二个例子：",
    "startMs": 0.0,
    "endMs": 785.8,
    "isFirstInItem": true
  },
  "scene4_1_1": {
    "duration": 1.428,
    "file": "/audio/statistic_1/scene4/scene4.mp3",
    "sceneId": "scene4",
    "order": 1,
    "subOrder": 1,
    "type": "正文",
    "text": "经常听人感叹：",
    "startMs": 785.8,
    "endMs": 2214.2,
    "isFirstInItem": false
  },
  "scene4_1_2": {
    "duration": 4.036,
    "file": "/audio/statistic_1/scene4/scene4.mp3",
    "sceneId": "scene4",
    "order": 1,
    "subOrder": 2,
    "type": "正文",
    "text": "“现在的华语乐坛不行了，还是以前的老歌好听”。",
    "startMs": 2214.2,
    "endMs": 6250.0,
    "isFirstInItem": false
  },
  "scene4_2_0": {
    "duration": 4.059,
    "file": "/audio/statistic_1/scene4/scene4.mp3",
    "sceneId": "scene4",
    "order": 2,
    "subOrder": 0,
    "type": "正文",
    "text": "真不是以前没烂歌，而是因为难听的歌早被时间淘汰了，",
    "startMs": 6250.0,
    "endMs": 10309.5,
    "isFirstInItem": false
  },
  "scene4_2_1": {
    "duration": 2.881,
    "file": "/audio/statistic_1/scene4/scene4.mp3",
    "sceneId": "scene4",
    "order": 2,
    "subOrder": 1,
    "type": "正文",
    "text": "能流传到今天、让你在耳机里听到的，",
    "startMs": 10309.5,
    "endMs": 13190.5,
    "isFirstInItem": false
  },
  "scene4_2_2": {
    "duration": 1.833,
    "file": "/audio/statistic_1/scene4/scene4.mp3",
    "sceneId": "scene4",
    "order": 2,
    "subOrder": 2,
    "type": "正文",
    "text": "全是“幸存”下来的神作",
    "startMs": 13190.5,
    "endMs": 15023.8,
    "isFirstInItem": false
  },
  "scene4_3_0": {
    "duration": 2.256,
    "file": "/audio/statistic_1/scene4/scene4.mp3",
    "sceneId": "scene4",
    "order": 3,
    "subOrder": 0,
    "type": "正文",
    "text": "这就是“幸存者偏差”",
    "startMs": 15023.8,
    "endMs": 17280.0,
    "isFirstInItem": false
  },
  "scene5_1_0": {
    "duration": 0.845,
    "file": "/audio/statistic_1/scene5/scene5.mp3",
    "sceneId": "scene5",
    "order": 1,
    "subOrder": 0,
    "type": "正文",
    "text": "第三个例子：",
    "startMs": 0.0,
    "endMs": 845.2,
    "isFirstInItem": true
  },
  "scene5_1_1": {
    "duration": 1.131,
    "file": "/audio/statistic_1/scene5/scene5.mp3",
    "sceneId": "scene5",
    "order": 1,
    "subOrder": 1,
    "type": "正文",
    "text": "再看个扎心的：",
    "startMs": 845.2,
    "endMs": 1976.2,
    "isFirstInItem": false
  },
  "scene5_1_2": {
    "duration": 5.869,
    "file": "/audio/statistic_1/scene5/scene5.mp3",
    "sceneId": "scene5",
    "order": 1,
    "subOrder": 2,
    "type": "正文",
    "text": "老师让学生实名填写教学质量调查表，结果收上来全是满分。",
    "startMs": 1976.2,
    "endMs": 7845.2,
    "isFirstInItem": false
  },
  "scene5_1_3": {
    "duration": 2.833,
    "file": "/audio/statistic_1/scene5/scene5.mp3",
    "sceneId": "scene5",
    "order": 1,
    "subOrder": 3,
    "type": "正文",
    "text": "老师高兴了，学生却无语了。",
    "startMs": 7845.2,
    "endMs": 10678.6,
    "isFirstInItem": false
  },
  "scene5_2_0": {
    "duration": 1.274,
    "file": "/audio/statistic_1/scene5/scene5.mp3",
    "sceneId": "scene5",
    "order": 2,
    "subOrder": 0,
    "type": "正文",
    "text": "为什么？",
    "startMs": 10678.6,
    "endMs": 11953.0,
    "isFirstInItem": false
  },
  "scene5_2_1": {
    "duration": 4.083,
    "file": "/audio/statistic_1/scene5/scene5.mp3",
    "sceneId": "scene5",
    "order": 2,
    "subOrder": 1,
    "type": "正文",
    "text": "因为在“实名制”的压力下，真实的想法被压抑了。",
    "startMs": 11953.0,
    "endMs": 16035.7,
    "isFirstInItem": false
  },
  "scene5_2_2": {
    "duration": 2.095,
    "file": "/audio/statistic_1/scene5/scene5.mp3",
    "sceneId": "scene5",
    "order": 2,
    "subOrder": 2,
    "type": "正文",
    "text": "这就是“应答偏差”。",
    "startMs": 16035.7,
    "endMs": 18131.0,
    "isFirstInItem": false
  },
  "scene5_3_0": {
    "duration": 4.009,
    "file": "/audio/statistic_1/scene5/scene5.mp3",
    "sceneId": "scene5",
    "order": 3,
    "subOrder": 0,
    "type": "正文",
    "text": "如果换成匿名调查，结果还会这么完美吗？",
    "startMs": 18131.0,
    "endMs": 22140.0,
    "isFirstInItem": false
  },
  "scene6_1_0": {
    "duration": 0.833,
    "file": "/audio/statistic_1/scene6/scene6.mp3",
    "sceneId": "scene6",
    "order": 1,
    "subOrder": 0,
    "type": "正文",
    "text": "第四个例子：",
    "startMs": 0.0,
    "endMs": 833.4,
    "isFirstInItem": true
  },
  "scene6_1_1": {
    "duration": 4.238,
    "file": "/audio/statistic_1/scene6/scene6.mp3",
    "sceneId": "scene6",
    "order": 1,
    "subOrder": 1,
    "type": "正文",
    "text": "某明星超话发起投票：“哥哥的新剧好看吗？”",
    "startMs": 833.4,
    "endMs": 5071.4,
    "isFirstInItem": false
  },
  "scene6_1_2": {
    "duration": 3.167,
    "file": "/audio/statistic_1/scene6/scene6.mp3",
    "sceneId": "scene6",
    "order": 1,
    "subOrder": 2,
    "type": "正文",
    "text": "结果99.9%投了“神作”。",
    "startMs": 5071.4,
    "endMs": 8238.1,
    "isFirstInItem": false
  },
  "scene6_2_0": {
    "duration": 3.726,
    "file": "/audio/statistic_1/scene6/scene6.mp3",
    "sceneId": "scene6",
    "order": 2,
    "subOrder": 0,
    "type": "正文",
    "text": "这叫“便利抽样”，也叫“在回音壁里找共鸣”。",
    "startMs": 8238.1,
    "endMs": 11964.3,
    "isFirstInItem": false
  },
  "scene6_3_0": {
    "duration": 3.381,
    "file": "/audio/statistic_1/scene6/scene6.mp3",
    "sceneId": "scene6",
    "order": 3,
    "subOrder": 0,
    "type": "正文",
    "text": "在粉丝圈子里找评价，本身就自带滤镜，",
    "startMs": 11964.3,
    "endMs": 15345.2,
    "isFirstInItem": false
  },
  "scene6_3_1": {
    "duration": 3.267,
    "file": "/audio/statistic_1/scene6/scene6.mp3",
    "sceneId": "scene6",
    "order": 3,
    "subOrder": 1,
    "type": "正文",
    "text": "得出的结论必然是碾压式的好评。",
    "startMs": 15345.2,
    "endMs": 18612.0,
    "isFirstInItem": false
  },
  "scene7_1_0": {
    "duration": 0.512,
    "file": "/audio/statistic_1/scene7/scene7.mp3",
    "sceneId": "scene7",
    "order": 1,
    "subOrder": 0,
    "type": "正文",
    "text": "所以，",
    "startMs": 0.0,
    "endMs": 511.9,
    "isFirstInItem": true
  },
  "scene7_1_1": {
    "duration": 3.809,
    "file": "/audio/statistic_1/scene7/scene7.mp3",
    "sceneId": "scene7",
    "order": 1,
    "subOrder": 1,
    "type": "正文",
    "text": "下次再看到那些让你焦虑、让你震惊的统计数据，",
    "startMs": 511.9,
    "endMs": 4321.4,
    "isFirstInItem": false
  },
  "scene7_1_2": {
    "duration": 1.762,
    "file": "/audio/statistic_1/scene7/scene7.mp3",
    "sceneId": "scene7",
    "order": 1,
    "subOrder": 2,
    "type": "正文",
    "text": "先别急着相信。",
    "startMs": 4321.4,
    "endMs": 6083.3,
    "isFirstInItem": false
  },
  "scene7_1_3": {
    "duration": 3.012,
    "file": "/audio/statistic_1/scene7/scene7.mp3",
    "sceneId": "scene7",
    "order": 1,
    "subOrder": 3,
    "type": "正文",
    "text": "样本无代表性，则结论不可信。",
    "startMs": 6083.3,
    "endMs": 9095.2,
    "isFirstInItem": false
  },
  "scene7_2_0": {
    "duration": 4.083,
    "file": "/audio/statistic_1/scene7/scene7.mp3",
    "sceneId": "scene7",
    "order": 2,
    "subOrder": 0,
    "type": "正文",
    "text": "多问一句：调查问了谁？是怎么问的？",
    "startMs": 9095.2,
    "endMs": 13178.6,
    "isFirstInItem": false
  },
  "scene7_3_0": {
    "duration": 3.273,
    "file": "/audio/statistic_1/scene7/scene7.mp3",
    "sceneId": "scene7",
    "order": 3,
    "subOrder": 0,
    "type": "正文",
    "text": "保持清醒，别让偏见伪装成真相。",
    "startMs": 13178.6,
    "endMs": 16452.0,
    "isFirstInItem": false
  }
}