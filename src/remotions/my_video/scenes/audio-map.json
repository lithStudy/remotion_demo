    "file": "/audio/my_video/scene5/01_正文_6.mp3",
    "sceneId": "scene5",
    "order": 1,
    "subOrder": 6,
    "type": "正文",
    "text": "希望以此来威胁重新签署一份对伊朗武器限制更大的协议"
